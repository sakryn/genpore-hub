# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# Gates the whole app. Any long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ACCESS_TOKEN=replace-with-a-long-random-string-32-chars-or-more

# Where the video files live. No trailing slash.
# Videos are NOT in this repo (5 modules x 2 languages is ~500MB; GitHub blocks
# files over 100MB). Host them on GenPore's server and point here.
# Leave blank to serve from /public/ during local testing.
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.genpore.com/training

# --- Postgres (Neon) ---
# Auto-injected when you create a Neon DB in Vercel's Storage tab and click
# "Connect to Project". Do not paste these by hand.
# POSTGRES_URL=...
# POSTGRES_PRISMA_URL=...
# POSTGRES_URL_NON_POOLING=...
